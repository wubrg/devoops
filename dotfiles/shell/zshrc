# Personal devoops zsh entrypoint.
# Source this from an existing ~/.zshrc after reviewing it.

export ZSH="${ZSH:-$HOME/.oh-my-zsh}"
export EDITOR="${EDITOR:-code -w}"

plugins=(
  autojump
  brew
  git
  history
  history-substring-search
  python
)

if [[ -r "$ZSH/oh-my-zsh.sh" ]]; then
  source "$ZSH/oh-my-zsh.sh"
fi

if command -v atuin >/dev/null 2>&1; then
  eval "$(atuin init zsh)"
fi

devoops_config_dir="${DEVOOPS_CONFIG_DIR:-$HOME/.config/devoops}"

for file in \
  "$devoops_config_dir/shell/path.zsh" \
  "$devoops_config_dir/shell/aliases.common.zsh" \
  "$devoops_config_dir/shell/functions.common.zsh" \
  "$devoops_config_dir/shell/local.zsh"; do
  [[ -r "$file" ]] && source "$file"
done
