# Personal devoops zsh entrypoint.
# Source this from an existing ~/.zshrc after reviewing it.

export ZSH="${ZSH:-$HOME/.oh-my-zsh}"
export EDITOR="${EDITOR:-code -w}"

plugins=(
  autojump
  brew
  git
  history
  history-substring-search
  python
)

if [[ -r "$ZSH/oh-my-zsh.sh" ]]; then
  source "$ZSH/oh-my-zsh.sh"
fi

if command -v atuin >/dev/null 2>&1; then
  eval "$(atuin init zsh)"
fi

for file in \
  "$HOME/.config/devoops/shell/path.zsh" \
  "$HOME/.config/devoops/shell/aliases.common.zsh" \
  "$HOME/.config/devoops/shell/functions.common.zsh" \
  "$HOME/.config/devoops/shell/profile.personal.zsh" \
  "$HOME/.config/devoops/shell/local.zsh"; do
  [[ -r "$file" ]] && source "$file"
done
